{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "{{BRAND_NAME}}",
  "url": "{{SITE_URL}}",
  "logo": "{{SITE_URL}}/assets/logo.svg",
  "sameAs": [
    "{{SOCIAL_URL_1}}",
    "{{SOCIAL_URL_2}}"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": ["{{LANGUAGE_1}}", "{{LANGUAGE_2}}"]
  }
}
